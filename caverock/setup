#!/usr/bin/env bash
# CaveRock setup — lightweight caveman mode for Claude Code
# Registers SessionStart + UserPromptSubmit hooks in ~/.claude/settings.json
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SETTINGS_FILE="${HOME}/.claude/settings.json"
SKILL_DIR="${HOME}/.claude/skills/caverock"

echo "=== CaveRock Setup ==="
echo "Lightweight caveman mode for Claude Code."
echo ""

# Check Node.js
if ! command -v node >/dev/null 2>&1; then
  echo "Error: Node.js is required but not found on PATH." >&2
  echo "Install from https://nodejs.org/ and try again." >&2
  exit 1
fi

# Conflict detection: check if CaveStack is already installed
if [ -f "$SETTINGS_FILE" ]; then
  if node -e "
    const s = JSON.parse(require('fs').readFileSync('$SETTINGS_FILE','utf8'));
    const hooks = JSON.stringify(s.hooks || {});
    if (hooks.includes('cavestack') || hooks.includes('caveman-activate')) {
      console.log('CONFLICT');
    }
  " 2>/dev/null | grep -q "CONFLICT"; then
    echo "CaveStack is already installed. CaveRock is included in CaveStack."
    echo "No action needed. Caveman mode is already active."
    exit 0
  fi
fi

# Copy hooks to skill directory
echo "Installing CaveRock to ${SKILL_DIR}..."
mkdir -p "${SKILL_DIR}/hooks"
cp "${SCRIPT_DIR}/hooks/caverock-activate.js" "${SKILL_DIR}/hooks/"
cp "${SCRIPT_DIR}/hooks/caverock-mode-tracker.js" "${SKILL_DIR}/hooks/"
cp "${SCRIPT_DIR}/SKILL.md" "${SKILL_DIR}/"
cp "${SCRIPT_DIR}/caverock-uninstall" "${SKILL_DIR}/"
chmod +x "${SKILL_DIR}/caverock-uninstall"

# Register hooks in settings.json
ACTIVATE_CMD="node \"${SKILL_DIR}/hooks/caverock-activate.js\""
TRACKER_CMD="node \"${SKILL_DIR}/hooks/caverock-mode-tracker.js\""

echo "Registering hooks..."
mkdir -p "$(dirname "$SETTINGS_FILE")"

node -e "
  const fs = require('fs');
  const settingsPath = '$SETTINGS_FILE';

  let settings = {};
  try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch {}

  if (!settings.hooks) settings.hooks = {};

  // SessionStart hook
  if (!settings.hooks.SessionStart) settings.hooks.SessionStart = [];
  const hasActivate = settings.hooks.SessionStart.some(e =>
    e.hooks && e.hooks.some(h => h.command && h.command.includes('caverock'))
  );
  if (!hasActivate) {
    settings.hooks.SessionStart.push({
      hooks: [{ type: 'command', command: $(node -e "process.stdout.write(JSON.stringify('$ACTIVATE_CMD'))") }]
    });
  }

  // UserPromptSubmit hook
  if (!settings.hooks.UserPromptSubmit) settings.hooks.UserPromptSubmit = [];
  const hasTracker = settings.hooks.UserPromptSubmit.some(e =>
    e.hooks && e.hooks.some(h => h.command && h.command.includes('caverock'))
  );
  if (!hasTracker) {
    settings.hooks.UserPromptSubmit.push({
      hooks: [{ type: 'command', command: $(node -e "process.stdout.write(JSON.stringify('$TRACKER_CMD'))") }]
    });
  }

  // Atomic write
  const tmp = settingsPath + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(settings, null, 2));
  fs.renameSync(tmp, settingsPath);
  console.log('Hooks registered.');
"

echo ""
echo "=== CaveRock installed ==="
echo "Open a new Claude Code session. Caveman mode will be active."
echo ""
echo "Commands:"
echo "  /caveman lite    — gentle compression"
echo "  /caveman full    — classic caveman (default)"
echo "  /caveman ultra   — maximum grunt"
echo "  stop caveman     — disable"
echo ""
echo "Uninstall: ~/.claude/skills/caverock/caverock-uninstall"
echo ""
echo "Want the full framework? Install CaveStack:"
echo "  git clone https://github.com/JerkyJesse/cavestack.git ~/.claude/skills/cavestack"
echo "  cd ~/.claude/skills/cavestack && ./setup"
