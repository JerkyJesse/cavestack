#!/bin/bash
# Shim: delegates to compiled find-browse binary, falls back to basic discovery.
# The compiled binary handles git root detection for workspace-local installs.
# On Windows (MSYS/Git Bash/Cygwin) the compiled outputs end in `.exe`.
case "${OSTYPE:-}" in
  msys*|cygwin*|win32*) EXE_SUFFIXES=".exe " ;;
  *) EXE_SUFFIXES=" " ;;
esac

DIR="$(cd "$(dirname "$0")/.." && pwd)/dist"
for SUFFIX in $EXE_SUFFIXES; do
  [ "$SUFFIX" = " " ] && SUFFIX=""
  if test -x "$DIR/find-browse$SUFFIX"; then
    exec "$DIR/find-browse$SUFFIX" "$@"
  fi
done

# Fallback: basic discovery with priority chain
ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
for MARKER in .codex .agents .claude; do
  for SUFFIX in $EXE_SUFFIXES; do
    [ "$SUFFIX" = " " ] && SUFFIX=""
    if [ -n "$ROOT" ] && test -x "$ROOT/$MARKER/skills/cavestack/browse/dist/browse$SUFFIX"; then
      echo "$ROOT/$MARKER/skills/cavestack/browse/dist/browse$SUFFIX"
      exit 0
    fi
    if test -x "$HOME/$MARKER/skills/cavestack/browse/dist/browse$SUFFIX"; then
      echo "$HOME/$MARKER/skills/cavestack/browse/dist/browse$SUFFIX"
      exit 0
    fi
  done
done
echo "ERROR: browse binary not found. Run: cd <skill-dir> && ./setup" >&2
exit 1
